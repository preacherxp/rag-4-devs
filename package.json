{
  "name": "ai-devs-4-builders-rag",
  "version": "1.0.0",
  "description": "AI Devs 4 RAG application",
  "keywords": [
    "ai-devs",
    "ai-devs-4",
    "ai-devs-4-builders",
    "ai-devs-4-builders-rag",
    "rag"
  ],
  "license": "MIT",
  "author": "Michał Hachuła <michal.hachula@purecode.sh>",
  "type": "module",
  "scripts": {
    "dev": "bun run dev:api & until curl -s http://localhost:4138 > /dev/null 2>&1; do sleep 0.5; done && bun run dev:ui",
    "dev:api": "bun --watch run src/index.ts",
    "dev:ui": "cd src/ui && bun run dev",
    "build:ui": "cd src/ui && bun run build",
    "start": "bun run src/index.ts",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "check:ui": "cd src/ui && bunx tsc --noEmit",
    "lint": "oxlint . --deny-warnings",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "prepare": "lefthook install",
    "precommit": "lefthook run pre-commit --force"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.11.0",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  }
}
