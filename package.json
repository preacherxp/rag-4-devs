  "license": "MIT",
  "author": "Michał Hachuła <michal.hachula@purecode.sh>",
  "description": "AI Devs 4 RAG application",
  "keywords": [
    "rag",
    "ai-devs",
    "ai-devs-4",
    "ai-devs-4-builders",
    "ai-devs-4-builders-rag"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run dev:api & bun run dev:ui",
    "dev:api": "bun --watch run src/index.ts",
    "dev:ui": "cd src/ui && bun run dev",
    "build:ui": "cd src/ui && bun run build",
    "start": "bun run src/index.ts",
    "check": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "hono": "^4.7.0",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.11.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
