# Server
PORT=4138

# LM Studio configuration
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_API_KEY=

# Provider for embeddings: "lmstudio" (local) or "openrouter" (cloud)
EMBED_PROVIDER=openrouter

# # Embedding model (openrouter)
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIMENSION=1536

# # Embedding model (lmstudio)
# EMBED_MODEL=nomic-embed-text
# EMBED_DIMENSION=768

# PostgreSQL (pgvector)
DATABASE_URL=postgresql://mateusz:adam@localhost:5433/jakub

# RAG directory (relative to project root or absolute)
RAG_DIR=./rag

# Logging
LOG_LEVEL=info

# OpenRouter (optional — enables cloud models like Claude, GPT-4, etc.)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=ai-devs-rag
